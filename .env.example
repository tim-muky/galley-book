# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for share links)
NEXT_PUBLIC_APP_URL=https://galleybook.com

# AI — Google AI Studio
GOOGLE_AI_API_KEY=your-gemini-api-key

# AI — Perplexity (optional, enables recommendations + fallback fetch)
PERPLEXITY_API_KEY=your-perplexity-api-key

# AI — Anthropic (reserved, not currently used in production)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email — Resend
RESEND_API_KEY=your-resend-api-key

# Apple — 10-char Team ID prefix (Apple Developer → Membership). Powers
# Universal Links via /.well-known/apple-app-site-association. Without it
# the AASA file is still served but iOS won't route https://app.galleybook.com/join/*
# into the native app.
APPLE_APP_ID_PREFIX=ABCDE12345

# Meta Marketing API — Campaign Studio (GAL-391). See lib/marketing/README.md
# for the full setup. The token is the only secret; the IDs are non-sensitive
# and have in-code defaults in lib/marketing/meta-config.ts (override here only
# when pointing at a different ad account / campaign).
#
# System User token with `ads_management` + `ads_read` (Meta Business Settings →
# System Users → Generate token). Never the page token.
META_SYSTEM_USER_TOKEN=your-system-user-token
# Browser pixel id (Conversions API dataset, GAL-47) — public, fires in the client.
NEXT_PUBLIC_META_PIXEL_ID=986119167455201
# Optional overrides for the standing ad assets (defaults live in meta-config.ts):
# META_AD_ACCOUNT_ID=1503605791229179
# META_PAGE_ID=1102747479595161
# META_IG_USER_ID=17841427581353009
# META_APP_ID=977813498304961
# META_CAMPAIGN_ID=52765486717127
# META_ADSET_ID=52767615705727

# TikTok Content Posting API — Campaign Studio TikTok publishing.
# Create an app at developers.tiktok.com with the Content Posting API product,
# scopes video.publish + video.upload, and run the OAuth flow once to obtain a
# refresh token. Verify the galleybook.com domain (URL prefix) in the portal so
# PULL_FROM_URL slide images are accepted. Public posting needs the audit;
# without it, posts publish privately (SELF_ONLY).
# TIKTOK_CLIENT_KEY=your-client-key
# TIKTOK_CLIENT_SECRET=your-client-secret
# TIKTOK_REFRESH_TOKEN=your-long-lived-refresh-token
# TIKTOK_ACCESS_TOKEN=          # optional: direct 24h token instead of refresh
# TIKTOK_PRIVACY_LEVEL=SELF_ONLY   # set PUBLIC_TO_EVERYONE once audited
# TIKTOK_POST_MODE=DIRECT_POST     # or MEDIA_UPLOAD (finish in TikTok's editor)
# TIKTOK_ASSET_BASE_URL=https://galleybook.com  # verified domain for slide URLs
